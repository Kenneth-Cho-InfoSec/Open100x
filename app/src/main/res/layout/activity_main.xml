<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/camera_surface"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="@color/bar_black"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/lensBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pill_background"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="@string/lens_loading"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/proModeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/pill_background"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="PRO"
            android:textColor="@color/violet_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.example.zoomhundred.overlay.HistogramView
            android:id="@+id/histogramView"
            android:layout_width="120dp"
            android:layout_height="46dp"
            android:layout_marginEnd="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/gestureHintButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/pill_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="?"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomControlsBar"
        android:layout_width="0dp"
        android:layout_height="236dp"
        android:background="@color/bar_black"
        android:elevation="16dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/zoomPresetBar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="6dp"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/secondaryControlBar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/mainCaptureRow"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.15"
                android:gravity="end|center_vertical"
                android:orientation="vertical"
                android:paddingEnd="12dp">

                <LinearLayout
                    android:id="@+id/hudRow"
                    android:layout_width="112dp"
                    android:layout_height="78dp"
                    android:background="@drawable/pill_background"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="10dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ISO"
                            android:textColor="@android:color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/hudIso"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="Yes"
                            android:textColor="@color/violet_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SS"
                            android:textColor="@android:color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/hudShutter"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="Yes"
                            android:textColor="@color/violet_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Auto"
                            android:textColor="@android:color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/hudWb"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="Yes"
                            android:textColor="@color/violet_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/captureStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/pill_background"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Stable"
                    android:textColor="@color/violet_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="visible" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="94dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/zoomDetailText"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:background="@drawable/pill_background"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="@string/loading_camera"
                    android:textColor="@color/detail_text"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/captureButton"
                    style="@style/Widget.ZoomHundred.ShutterButton"
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:layout_marginTop="4dp"
                    android:contentDescription="@string/capture"
                    android:text=""
                    app:cornerRadius="41dp"
                    app:strokeColor="@color/violet_primary"
                    app:strokeWidth="3dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/zoomValueText"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1.15"
                android:background="@drawable/pill_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/default_zoom_ratio"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:keepScreenOn="true"
        app:implementationMode="compatible"
        app:layout_constrainedHeight="true"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/bottomControlsBar"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topPanel"
        app:scaleType="fillCenter" />

    <com.example.zoomhundred.overlay.GridOverlayView
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <com.example.zoomhundred.overlay.HeatHazeView
        android:id="@+id/heatHazeView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <com.example.zoomhundred.overlay.ExtremeZoomOverlayView
        android:id="@+id/extremeOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <ImageView
        android:id="@+id/freezeScopeView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#EE000000"
        android:clickable="true"
        android:contentDescription="@string/freeze_scope"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <View
        android:id="@+id/nightOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#99FF0000"
        android:clickable="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <View
        android:id="@+id/gestureLayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <View
        android:id="@+id/edgeGlowLeft"
        android:layout_width="18dp"
        android:layout_height="0dp"
        android:background="#667C3AED"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <View
        android:id="@+id/edgeGlowRight"
        android:layout_width="18dp"
        android:layout_height="0dp"
        android:background="#667C3AED"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <View
        android:id="@+id/edgeGlowTop"
        android:layout_width="0dp"
        android:layout_height="18dp"
        android:background="#667C3AED"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <View
        android:id="@+id/edgeGlowBottom"
        android:layout_width="0dp"
        android:layout_height="18dp"
        android:background="#667C3AED"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView" />

    <LinearLayout
        android:id="@+id/shakeMeterRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView">

        <com.example.zoomhundred.overlay.ShakeMeterView
            android:id="@+id/shakeMeter"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/shakeMeterLabel"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="WAIT"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/gestureHintOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:background="@drawable/panel_scrim"
        android:elevation="24dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/gesture_hints"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/gesture_hint_body"
            android:textColor="@color/detail_text"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@drawable/panel_scrim"
        android:orientation="vertical"
        android:padding="14dp"
        android:translationY="420dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomControlsBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/zoom_menu_hint"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/resize_bar"
            android:textColor="@color/detail_text"
            android:textSize="11sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/zoomSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="0.5"
            android:value="1"
            android:valueFrom="1"
            android:valueTo="100"
            app:haloColor="@color/slider_halo"
            app:labelBehavior="floating"
            app:thumbColor="@color/violet_primary"
            app:trackColorActive="@color/violet_primary"
            app:trackColorInactive="@color/slider_inactive" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/switchLensButton"
                style="@style/Widget.ZoomHundred.ControlButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:text="@string/switch_lens" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/resetZoomButton"
                style="@style/Widget.ZoomHundred.ControlButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/info" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/proSettingsButton"
                style="@style/Widget.ZoomHundred.ProButton"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/pro_settings" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/lockZoomButton"
                style="@style/Widget.ZoomHundred.ControlButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/lock_zoom" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/flashlightButton"
                style="@style/Widget.ZoomHundred.ControlButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/flash_off" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/gridButton"
                style="@style/Widget.ZoomHundred.ControlButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/grid_off" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
